# Terraform ignores
# Ignore the local .terraform directory (which contains providers and modules)
# This is usually the source of the large size (hundreds of MBs)
**/.terraform/*

# .tfstate files contain sensitive information and local state
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all variables files that might contain secrets
*.tfvars
*.tfvars.json

# Override files should be ignored
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore the zip files generated by the archive provider
terraform/modules/lambda/*.zip

# Standard Python ignores
__pycache__/
*.py[cod]
*$py.class

# OS ignores
.DS_Store
